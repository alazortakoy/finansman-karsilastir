---
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Tasarruf Finansman Sistemi (Evim) ile Banka Konut Kredisini ve Kendin Biriktir alternatifini Net Bugünkü Değer bazında karşılaştırın.',
} = Astro.props;

const siteTitle = 'FinansmanKarşılaştır';
const fullTitle = title === siteTitle ? title : `${title} | ${siteTitle}`;
---

<!doctype html>
<html lang="tr" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0D9488" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    {/* Google Fonts: Plus Jakarta Sans + Inter */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Plus+Jakarta+Sans:wght@600;700&display=swap"
      rel="stylesheet"
    />

    <title>{fullTitle}</title>
  </head>
  <body class="min-h-screen flex flex-col bg-brand-bg font-body text-brand-text antialiased">
    <Navbar />
    <main class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
