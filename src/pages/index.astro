---
import Base from '../layouts/Base.astro';
import { Icon } from 'astro-icon/components';
import WizardNav from '../components/calculator/WizardNav.astro';
import CommonInputs from '../components/calculator/CommonInputs.astro';
import AdvancedInputs from '../components/calculator/AdvancedInputs.astro';
import BankaInputs from '../components/calculator/BankaInputs.astro';
import EvimInputs from '../components/calculator/EvimInputs.astro';
import BirikimInputs from '../components/calculator/BirikimInputs.astro';
import ResultsSummary from '../components/calculator/ResultsSummary.astro';
import CashFlowTable from '../components/calculator/CashFlowTable.astro';
---

<Base title="Konut Finansman Karşılaştırma Aracı" description="Evim Sistemi, Banka Kredisi ve Kendin Biriktir seçeneklerini Net Bugünkü Değer bazında karşılaştırın.">
  <section class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
    {/* Hero */}
    <div class="text-center max-w-2xl mx-auto mb-8 sm:mb-12">
      <h1 class="font-heading text-3xl sm:text-4xl lg:text-5xl font-bold text-brand-heading tracking-tight">
        Konut Finansmanınızı
        <span class="text-brand-primary">Akıllıca</span> Karşılaştırın
      </h1>
      <p class="mt-4 text-base sm:text-lg text-brand-text leading-relaxed">
        Tasarruf Finansman Sistemi (Evim), Banka Kredisi ve Kendin Biriktir
        seçeneklerini Net Bugünkü Değer bazında analiz edin.
      </p>
    </div>

    {/* Calculator Wizard */}
    <div id="calculator">
      <WizardNav />

      {/* Wizard Steps */}
      <CommonInputs />
      <AdvancedInputs />
      <BankaInputs />
      <EvimInputs />
      <BirikimInputs />

      {/* Step 6: Results */}
      <div id="wizard-step-6" class="wizard-step hidden">
        <div class="space-y-6">
          {/* Calculate Button */}
          <div class="text-center space-y-3">
            <button
              type="button"
              id="btn-karsilastir"
              class="w-full sm:w-auto px-8 py-4 rounded-xl bg-brand-primary text-white font-heading font-semibold text-lg shadow-lg shadow-brand-primary/25 hover:bg-brand-secondary hover:shadow-xl hover:shadow-brand-secondary/25 active:scale-[0.98] transition-all"
            >
              <Icon name="tabler:arrows-exchange" class="w-5 h-5 inline-block mr-2 -mt-0.5" />
              Karşılaştır
            </button>
            <p id="error-message" class="hidden text-sm text-brand-danger font-medium"></p>
          </div>

          {/* Results */}
          <ResultsSummary />
          <CashFlowTable />
        </div>
      </div>
    </div>
  </section>
</Base>

<style is:global>
  .active-asset-btn,
  .active-evim-btn,
  .active-taksit-btn,
  .active-birikim-btn,
  .active-senaryo-btn,
  .active-cf-btn {
    background-color: #0D9488;
    color: white;
    box-shadow: 0 1px 3px 0 rgb(13 148 136 / 0.3);
  }

  .calc-input.input-error {
    border-color: #EF4444;
  }
</style>

<script>
  import {
    yillikToAylik,
    hesaplaTeslimAyi,
    hesaplaSabitTaksit,
    hesaplaBankaNBD,
    hesaplaEvimNBD,
    hesaplaBirikimNBD,
    hesaplaCekilisliSenaryolar,
  } from '../lib/engine';
  import type {
    CommonParams,
    BankaParams,
    EvimParams,
    BirikimParams,
    TaksitPlan,
    ModelSonuc,
    BirikimModu,
  } from '../lib/engine';
  import type { CekilisliSonuc } from '../lib/engine/cekilisli';

  // ── Utilities ──────────────────────────────────────────────

  const TL = new Intl.NumberFormat('tr-TR', {
    style: 'currency',
    currency: 'TRY',
    minimumFractionDigits: 0,
    maximumFractionDigits: 0,
  });

  const TL2 = new Intl.NumberFormat('tr-TR', {
    style: 'currency',
    currency: 'TRY',
    minimumFractionDigits: 2,
    maximumFractionDigits: 2,
  });

  const NUM = new Intl.NumberFormat('tr-TR');

  function parseTL(val: string): number {
    if (!val) return 0;
    return parseFloat(val.replace(/\./g, '').replace(',', '.')) || 0;
  }

  function formatTLInput(input: HTMLInputElement) {
    const raw = input.value.replace(/\D/g, '');
    if (!raw) { input.value = ''; return; }
    input.value = NUM.format(parseInt(raw, 10));
  }

  function getNum(id: string): number {
    const el = document.getElementById(id) as HTMLInputElement | null;
    if (!el) return 0;
    if (el.type === 'number') return parseFloat(el.value) || 0;
    return parseTL(el.value);
  }

  function getStr(id: string): string {
    return (document.getElementById(id) as HTMLInputElement | null)?.value ?? '';
  }

  function $(id: string) { return document.getElementById(id); }

  // ── TL input formatting ────────────────────────────────────

  document.querySelectorAll<HTMLInputElement>('input[inputmode="numeric"]').forEach(input => {
    input.addEventListener('input', () => formatTLInput(input));
    if (input.value && input.value !== '0') formatTLInput(input);
  });

  // ── Wizard Navigation ─────────────────────────────────────

  let currentStep = 1;
  const TOTAL_STEPS = 6;

  function showStep(step: number) {
    document.querySelectorAll('.wizard-step').forEach(el => el.classList.add('hidden'));
    $(`wizard-step-${step}`)?.classList.remove('hidden');

    // Update progress indicators
    document.querySelectorAll('[data-wizard-step-indicator]').forEach(el => {
      const s = parseInt((el as HTMLElement).dataset.wizardStepIndicator || '0');
      const circle = el.querySelector('.wizard-step-circle') as HTMLElement;
      const label = el.querySelector('.wizard-step-label') as HTMLElement;
      const line = el.querySelector('.wizard-step-line') as HTMLElement;

      if (circle) {
        if (s <= step) {
          circle.className = 'wizard-step-circle w-8 h-8 sm:w-9 sm:h-9 rounded-full flex items-center justify-center text-xs sm:text-sm font-bold transition-all bg-brand-primary text-white shadow-md shadow-brand-primary/30';
        } else {
          circle.className = 'wizard-step-circle w-8 h-8 sm:w-9 sm:h-9 rounded-full flex items-center justify-center text-xs sm:text-sm font-bold transition-all bg-brand-surface text-brand-text border border-brand-border';
        }
      }
      if (label) {
        label.className = `wizard-step-label mt-1.5 text-[10px] sm:text-xs font-medium text-center transition-colors leading-tight ${s <= step ? 'text-brand-primary' : 'text-brand-text/60'}`;
      }
    });

    // Update connecting lines
    document.querySelectorAll('.wizard-step-line').forEach(el => {
      const parent = (el as HTMLElement).closest('[data-wizard-step-indicator]');
      if (parent) {
        const s = parseInt((parent as HTMLElement).dataset.wizardStepIndicator || '0');
        if (s < step) {
          el.classList.add('bg-brand-primary');
          el.classList.remove('bg-brand-border');
        } else {
          el.classList.remove('bg-brand-primary');
          el.classList.add('bg-brand-border');
        }
      }
    });

    // Prev/Next buttons
    const prev = $('wizard-prev') as HTMLButtonElement;
    const next = $('wizard-next') as HTMLButtonElement;
    if (prev) prev.classList.toggle('hidden', step === 1);
    if (next) next.textContent = step === TOTAL_STEPS ? 'Karşılaştır' : 'Devam Et';

    currentStep = step;

    // Auto-compute dependent fields when entering certain steps
    if (step === 4) updateEvimDerivedFields();
    if (step === 5) updateBirikimDerivedFields();
    if (step === 6) runCalculation();
  }

  $('wizard-next')?.addEventListener('click', () => {
    if (currentStep === TOTAL_STEPS) {
      runCalculation();
      return;
    }
    if (!validateStep(currentStep)) return;
    showStep(currentStep + 1);
  });

  $('wizard-prev')?.addEventListener('click', () => {
    if (currentStep > 1) showStep(currentStep - 1);
  });

  // Allow clicking step indicators to navigate
  document.querySelectorAll('[data-wizard-step-indicator]').forEach(el => {
    el.addEventListener('click', () => {
      const target = parseInt((el as HTMLElement).dataset.wizardStepIndicator || '0');
      if (target < currentStep) showStep(target);
      // Only allow forward navigation to steps already visited
      if (target === currentStep + 1 && validateStep(currentStep)) showStep(target);
    });
  });

  // ── Step Validation ────────────────────────────────────────

  function validateStep(step: number): boolean {
    clearError();
    switch (step) {
      case 1: {
        const F = getNum('input-F');
        const P = getNum('input-P');
        if (F < 100_000 || F > 100_000_000) {
          showError('Konut/araç değeri 100.000 — 100.000.000 TL arasında olmalıdır.');
          return false;
        }
        if (P < 0 || P >= F) {
          showError('Peşinat 0 ile konut değerinden düşük olmalıdır.');
          return false;
        }
        return true;
      }
      case 2: {
        const R = getNum('input-R_yillik');
        if (R < 0 || R > 500) { showError('İskonto oranı %0–%500 arasında olmalıdır.'); return false; }
        return true;
      }
      case 3: {
        const r = getNum('input-r_b_yillik');
        const n = getNum('input-n_b');
        if (r < 0.01 || r > 500) { showError('Banka faiz oranı %0.01–%500 arasında olmalıdır.'); return false; }
        if (n < 12 || n > 360) { showError('Kredi vadesi 12–360 ay arasında olmalıdır.'); return false; }
        return true;
      }
      case 4: {
        const O = getNum('input-O_oran');
        const n = getNum('input-n_e');
        const asset = getStr('input-assetType');
        const maxV = asset === 'konut' ? 240 : 120;
        if (O < 0 || O > 20) { showError('Organizasyon ücreti oranı %0–%20 arasında olmalıdır.'); return false; }
        if (n < 12 || n > maxV) { showError(`Toplam vade 12–${maxV} ay arasında olmalıdır.`); return false; }
        return true;
      }
      case 5:
        return true; // BirikimInputs has sensible defaults
      default:
        return true;
    }
  }

  // ── Toggle helpers ─────────────────────────────────────────

  function setupToggle(toggleId: string, panelId: string) {
    const toggle = $(toggleId) as HTMLInputElement | null;
    const panel = $(panelId);
    if (!toggle || !panel) return;
    toggle.addEventListener('change', () => panel.classList.toggle('hidden', !toggle.checked));
  }

  setupToggle('toggle-kira', 'kira-panel');
  setupToggle('toggle-kiraDestegi', 'kiraDestegi-panel');

  // ── Button group helper ────────────────────────────────────

  function setupBtnGroup(
    btnClass: string,
    activeClass: string,
    hiddenId: string,
    dataKey: string,
    cb?: (val: string) => void,
  ) {
    document.querySelectorAll<HTMLButtonElement>(`.${btnClass}`).forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll(`.${btnClass}`).forEach(b => {
          b.classList.remove(activeClass);
          b.classList.add('text-brand-text', 'hover:text-brand-heading');
        });
        btn.classList.add(activeClass);
        btn.classList.remove('text-brand-text', 'hover:text-brand-heading');
        const val = (btn.dataset as any)[dataKey] ?? '';
        const h = $(hiddenId) as HTMLInputElement;
        if (h) h.value = val;
        cb?.(val);
      });
    });
  }

  // Asset type toggle — also update BSMV/KKDF defaults
  setupBtnGroup('asset-type-btn', 'active-asset-btn', 'input-assetType', 'asset', val => {
    const isKonut = val === 'konut';
    const bsmv = $('input-bsmvOrani') as HTMLInputElement;
    const kkdf = $('input-kkdfOrani') as HTMLInputElement;
    if (bsmv) bsmv.value = isKonut ? '0' : '15';
    if (kkdf) kkdf.value = isKonut ? '0' : '15';
    // Update hints
    const bsmvHint = $('hint-bsmv');
    const kkdfHint = $('hint-kkdf');
    if (bsmvHint) bsmvHint.textContent = isKonut ? 'Konut: %0 (istisna) / Araç: %15' : 'Araç: %15 / Konut: %0 (istisna)';
    if (kkdfHint) kkdfHint.textContent = isKonut ? 'Konut: %0 / Araç: %15' : 'Araç: %15 / Konut: %0';
  });

  // Evim model toggle
  setupBtnGroup('evim-model-btn', 'active-evim-btn', 'input-evim-model', 'evimModel', val => {
    $('teslim-cekilissiz')?.classList.toggle('hidden', val === 'cekilisli');
    $('teslim-cekilisli')?.classList.toggle('hidden', val !== 'cekilisli');
  });

  // Taksit plan toggle
  setupBtnGroup('taksit-plan-btn', 'active-taksit-btn', 'input-taksitPlan', 'taksitPlan', val => {
    document.querySelectorAll('.plan-fields').forEach(p => p.classList.add('hidden'));
    $(`plan-${val}`)?.classList.remove('hidden');
    if (val === 'sabit') updateSabitTaksitDisplay();
  });

  // Birikim mode toggle
  setupBtnGroup('birikim-mod-btn', 'active-birikim-btn', 'input-birikimMod', 'birikimMod', val => {
    $('birikim-ayHesapla')?.classList.toggle('hidden', val !== 'ayHesapla');
    $('birikim-tutarHesapla')?.classList.toggle('hidden', val !== 'tutarHesapla');
  });

  // ── Derived field updates ──────────────────────────────────

  // Sync banka vade to evim vade
  function syncVade() {
    const n_b = getNum('input-n_b');
    const ne = $('input-n_e') as HTMLInputElement;
    const syncInfo = $('sync-vade-info');
    if (ne && ne.value === '' || ne?.dataset.userOverride !== 'true') {
      if (ne) ne.value = String(n_b);
    }
    if (syncInfo) syncInfo.textContent = `${n_b} ay`;
  }

  $('input-n_b')?.addEventListener('change', syncVade);

  // Auto sabit taksit display
  function updateSabitTaksitDisplay() {
    const F = getNum('input-F');
    const P = getNum('input-P');
    const n_e = getNum('input-n_e');
    const display = $('sabit-taksit-display');
    if (display && n_e > 0) {
      const taksit = hesaplaSabitTaksit(F, P, n_e);
      display.textContent = TL.format(Math.round(taksit));
    }
  }

  // Listen for changes that affect sabit taksit
  ['input-F', 'input-P', 'input-n_e'].forEach(id => {
    $(id)?.addEventListener('change', updateSabitTaksitDisplay);
    $(id)?.addEventListener('input', updateSabitTaksitDisplay);
  });

  // Auto teslimat ayı
  function updateTeslimDisplay() {
    const F = getNum('input-F');
    const P = getNum('input-P');
    const n_e = getNum('input-n_e');
    const plan = buildTaksitPlan();
    const display = $('teslim-display');
    const hidden = $('input-t_teslim') as HTMLInputElement;

    if (display && plan && F > 0 && n_e > 0) {
      const t = hesaplaTeslimAyi(F, P, plan, n_e);
      display.textContent = `${t}. ay`;
      if (hidden) hidden.value = String(t);
    }
  }

  // Update Evim derived fields when entering step 4
  function updateEvimDerivedFields() {
    syncVade();
    updateSabitTaksitDisplay();
    updateTeslimDisplay();
  }

  // Update biriktir display when entering step 5
  function updateBirikimDerivedFields() {
    const R_yillik = getNum('input-R_yillik');
    const display = $('biriktir-getiri-display');
    if (display) display.textContent = `%${R_yillik}`;
  }

  // ── Build params from form ─────────────────────────────────

  function buildTaksitPlan(): TaksitPlan | null {
    const tip = getStr('input-taksitPlan');
    const F = getNum('input-F');
    const P = getNum('input-P');
    const n_e = getNum('input-n_e');

    switch (tip) {
      case 'sabit':
        return { tip: 'sabit', aylikTutar: hesaplaSabitTaksit(F, P, n_e) };
      case 'yillikArtisli':
        return { tip: 'yillikArtisli', baslangicTutar: getNum('input-baslangicTutar'), yillikArtisOrani: getNum('input-yillikArtisOrani') / 100 };
      case 'teslimatSonrasiArtisli':
        return { tip: 'teslimatSonrasiArtisli', teslimOncesiTutar: getNum('input-teslimOncesiTutar'), teslimSonrasiTutar: getNum('input-teslimSonrasiTutar'), yillikArtisOrani: getNum('input-teslimSonrasiArtis') / 100 };
      default: return null;
    }
  }

  function showError(msg: string) {
    const el = $('error-message');
    if (el) { el.textContent = msg; el.classList.remove('hidden'); }
  }

  function clearError() {
    const el = $('error-message');
    if (el) { el.textContent = ''; el.classList.add('hidden'); }
  }

  function buildCommonParams(): CommonParams | null {
    const F = getNum('input-F');
    const P = getNum('input-P');
    const assetType = getStr('input-assetType') as 'konut' | 'arac';

    if (F < 100_000 || F > 100_000_000) {
      showError('Konut/araç değeri 100.000 — 100.000.000 TL arasında olmalıdır.');
      return null;
    }
    if (P < 0 || P >= F) {
      showError('Peşinat 0 ile konut değerinden düşük olmalıdır.');
      return null;
    }

    const common: CommonParams = { F, P, assetType };

    const R_yillik = getNum('input-R_yillik');
    if (R_yillik > 0) {
      common.R = yillikToAylik(R_yillik / 100);
    }

    const r_ev_yillik = getNum('input-r_ev_yillik');
    if (r_ev_yillik !== 0) common.r_ev = yillikToAylik(r_ev_yillik / 100);

    if (($('toggle-kira') as HTMLInputElement)?.checked) {
      common.K_0 = getNum('input-K_0');
      const rk = getNum('input-r_kira_yillik');
      common.r_kira = rk > 0 ? yillikToAylik(rk / 100) : 0;
    }

    return common;
  }

  function buildBankaParams(): BankaParams | null {
    const r_b_yillik = getNum('input-r_b_yillik');
    const n_b = getNum('input-n_b');

    if (r_b_yillik < 0.01 || r_b_yillik > 500) { showError('Banka faiz oranı geçersiz.'); return null; }
    if (n_b < 12 || n_b > 360) { showError('Kredi vadesi 12–360 ay arasında olmalıdır.'); return null; }

    const p: BankaParams = {
      r_b: yillikToAylik(r_b_yillik / 100),
      n_b,
      // Extra costs are always visible now
      dosyaMasrafi: getNum('input-dosyaMasrafi'),
      ekspertizUcreti: getNum('input-ekspertizUcreti'),
      ipotekHarciOrani: getNum('input-ipotekHarciOrani') / 1000, // convert from ‰
      bsmvOrani: getNum('input-bsmvOrani') / 100,
      kkdfOrani: getNum('input-kkdfOrani') / 100,
      daskYillik: getNum('input-banka-dask'),
      konutSigortaYillik: getNum('input-banka-konutSigorta'),
      hayatSigortaYillik: getNum('input-banka-hayatSigorta'),
    };

    return p;
  }

  function buildEvimParams(common: CommonParams): EvimParams | null {
    const model = getStr('input-evim-model') as 'cekilissiz' | 'cekilisli';
    const O_oran_pct = getNum('input-O_oran');
    const n_e = getNum('input-n_e');

    if (O_oran_pct < 0 || O_oran_pct > 20) { showError('Organizasyon ücreti oranı %0–%20 arasında olmalıdır.'); return null; }

    const maxV = common.assetType === 'konut' ? 240 : 120;
    if (n_e < 12 || n_e > maxV) { showError(`Toplam vade 12–${maxV} ay arasında olmalıdır.`); return null; }

    const taksitPlani = buildTaksitPlan();
    if (!taksitPlani) { showError('Taksit planı bilgilerini doldurun.'); return null; }

    let t_teslim: number;
    if (model === 'cekilisli') {
      t_teslim = Math.round((getNum('input-grupBuyuklugu') || 100) / 2);
    } else {
      t_teslim = getNum('input-t_teslim');
      if (!t_teslim) t_teslim = hesaplaTeslimAyi(common.F, common.P, taksitPlani, n_e);
    }

    if (t_teslim < 1 || t_teslim > n_e) { showError('Teslimat ayı 1 ile toplam vade arasında olmalıdır.'); return null; }

    return {
      model,
      O_oran: O_oran_pct / 100,
      n_e,
      t_teslim,
      taksitPlani,
      orgUcretPesinOrani: Math.max(0.50, getNum('input-orgPesinOran') / 100),
      orgUcretTaksitSayisi: Math.min(4, getNum('input-orgTaksitSayisi')),
      kiraDestegi: ($('toggle-kiraDestegi') as HTMLInputElement)?.checked ? getNum('input-kiraDestegi') : undefined,
    };
  }

  function buildBirikimParams(evimParams: EvimParams): BirikimParams | null {
    const R_yillik = getNum('input-R_yillik');
    const stopaj = getNum('input-stopajOrani') / 100;
    const mod = getStr('input-birikimMod') as BirikimModu;

    const brutAylik = yillikToAylik(R_yillik / 100);
    const netAylik = brutAylik * (1 - stopaj);

    const birikimP: BirikimParams = {
      r_mevduat: netAylik,
      stopajOrani: stopaj,
      mod,
    };

    if (mod === 'ayHesapla') {
      let aylik = getNum('input-aylikBirikim');
      // Default to Evim sabit taksit if empty
      if (!aylik && evimParams.taksitPlani.tip === 'sabit') {
        aylik = evimParams.taksitPlani.aylikTutar;
      }
      if (!aylik) { showError('Aylık birikim tutarı girin.'); return null; }
      birikimP.aylikBirikim = aylik;
      const artis = getNum('input-birikimArtisOrani');
      birikimP.aylikBirikimArtisOrani = artis > 0 ? yillikToAylik(artis / 100) : 0;
    } else if (mod === 'tutarHesapla') {
      let hedef = getNum('input-birikimHedefAy');
      if (!hedef) hedef = evimParams.t_teslim;
      if (!hedef || hedef < 1) { showError('Hedef ay belirtin.'); return null; }
      birikimP.hedefAy = hedef;
      const artis = getNum('input-tutarBirikimArtis');
      birikimP.aylikBirikimArtisOrani = artis > 0 ? yillikToAylik(artis / 100) : 0;
    }

    return birikimP;
  }

  // ── Results rendering ──────────────────────────────────────

  let lastResults: {
    banka: ModelSonuc; evim: ModelSonuc; biriktir: ModelSonuc;
    cekilisli?: CekilisliSonuc; enKarliModel: string;
  } | null = null;

  let currentCF: 'banka' | 'evim' | 'biriktir' = 'banka';
  let cfPage = 0;
  const CF_SIZE = 24;

  const MODEL_META: Record<string, { title: string; subtitle: string; iconBg: string; iconColor: string; svg: string }> = {
    banka: {
      title: 'Banka Kredisi',
      subtitle: 'Faizli kredi ile konut alımı',
      iconBg: 'bg-blue-100', iconColor: 'text-blue-600',
      svg: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18"/><path d="M3 10h18"/><path d="M5 6l7-3l7 3"/><path d="M4 10v11"/><path d="M20 10v11"/><path d="M8 14v3"/><path d="M12 14v3"/><path d="M16 14v3"/></svg>',
    },
    evim: {
      title: 'Evim Sistemi',
      subtitle: 'Tasarruf finansman sistemi',
      iconBg: 'bg-teal-100', iconColor: 'text-teal-600',
      svg: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12l-2 0l9-9l9 9l-2 0"/><path d="M5 12v7a2 2 0 002 2h10a2 2 0 002-2v-7"/><path d="M9 21v-6a2 2 0 012-2h2a2 2 0 012 2v6"/></svg>',
    },
    biriktir: {
      title: 'Kendin Biriktir',
      subtitle: 'Yatırıma yönlendirip peşin alım',
      iconBg: 'bg-amber-100', iconColor: 'text-amber-600',
      svg: '<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 11v.01"/><path d="M5.173 8.378a3 3 0 114.656-1.377"/><path d="M16 4v3.803A6.019 6.019 0 0118.658 11h1.341a1 1 0 011 1v2a1 1 0 01-1 1h-1.342a6 6 0 01-1.658 2.473V19.5a1.5 1.5 0 01-3 0v-.583a6 6 0 01-1 .083h-4a6 6 0 01-1-.083v.583a1.5 1.5 0 01-3 0v-2.027A6 6 0 013.063 8.735a3 3 0 012.11-5.357"/></svg>',
    },
  };

  function getExtras(key: string, r: ModelSonuc): string[][] {
    const rows: string[][] = [];
    if (key === 'banka' && r.toplamFaiz) rows.push(['Toplam Faiz', TL.format(r.toplamFaiz)]);
    if (key === 'evim') {
      if (r.toplamOrgUcreti) rows.push(['Org. Ücreti', TL.format(r.toplamOrgUcreti)]);
      if (r.toplamKira) rows.push(['Toplam Kira', TL.format(r.toplamKira)]);
    }
    if (key === 'biriktir') {
      if (r.birikim) {
        if (r.birikim.hesaplananAy) rows.push(['Hedef Ay', `${r.birikim.hesaplananAy}. ay`]);
        if (r.birikim.gerekliAylikTutar) rows.push(['Aylık Tutar', TL.format(r.birikim.gerekliAylikTutar)]);
        rows.push(['Birikim', TL.format(r.birikim.toplamBirikim)]);
        rows.push(['Hedef Değer', TL.format(r.birikim.hedefKonutDegeri)]);
        rows.push([r.birikim.yeterliMi ? 'Fazla' : 'Eksik', TL.format(Math.abs(r.birikim.fark))]);
      }
      if (r.toplamKira) rows.push(['Toplam Kira', TL.format(r.toplamKira)]);
    }
    return rows;
  }

  function renderResults(banka: ModelSonuc, evim: ModelSonuc, biriktir: ModelSonuc, winner: string, cek?: CekilisliSonuc) {
    lastResults = { banka, evim, biriktir, cekilisli: cek, enKarliModel: winner };

    $('results-section')?.classList.remove('hidden');
    $('warning-no-discount')?.classList.toggle('hidden', getNum('input-R_yillik') > 0);

    const isCek = getStr('input-evim-model') === 'cekilisli';
    $('cekilisli-tabs')?.classList.toggle('hidden', !isCek);

    if (isCek) {
      MODEL_META.evim.subtitle = 'Çekilişli model (beklenen senaryo)';
    } else {
      MODEL_META.evim.subtitle = 'Çekilişsiz tasarruf finansman';
    }

    const grid = $('results-grid')!;
    grid.innerHTML = '';

    const results: Record<string, ModelSonuc> = { banka, evim, biriktir };

    for (const key of ['banka', 'evim', 'biriktir']) {
      const m = MODEL_META[key];
      const r = results[key];
      const isW = key === winner;

      const extras = getExtras(key, r);
      let extrasHtml = '';
      if (extras.length) {
        extrasHtml = `<div class="space-y-1.5 text-sm border-t border-brand-border-light pt-3 mt-4">${extras.map(([k, v]) => `<div class="flex justify-between"><span class="text-brand-text">${k}</span><span class="font-medium text-brand-heading">${v}</span></div>`).join('')}</div>`;
      }

      const card = document.createElement('div');
      card.className = `bg-white border rounded-xl p-5 sm:p-6 shadow-sm hover:shadow-md transition-all relative overflow-hidden ${isW ? 'border-brand-success ring-2 ring-brand-success/30' : 'border-brand-border hover:border-brand-primary/30'}`;
      card.innerHTML = `
        ${isW ? '<div class="absolute top-0 right-0"><div class="bg-brand-success text-white text-xs font-bold px-3 py-1 rounded-bl-lg">En Karlı</div></div>' : ''}
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-lg ${m.iconBg} ${m.iconColor} flex items-center justify-center shrink-0">${m.svg}</div>
          <div>
            <h3 class="font-heading text-base font-semibold text-brand-heading">${m.title}</h3>
            <p class="text-xs text-brand-text">${m.subtitle}</p>
          </div>
        </div>
        <div class="mb-1">
          <p class="text-xs text-brand-text mb-0.5">Maliyet (NBD)</p>
          <p class="font-heading text-2xl sm:text-3xl font-bold ${isW ? 'text-brand-success' : 'text-brand-heading'}" style="font-variant-numeric:tabular-nums">${TL.format(r.maliyetNBD)}</p>
        </div>
        <div class="mb-2">
          <p class="text-xs text-brand-text mb-0.5">Nominal Toplam Ödeme</p>
          <p class="text-base font-medium text-brand-text" style="font-variant-numeric:tabular-nums">${TL.format(r.toplamOdeme)}</p>
        </div>
        ${extrasHtml}
      `;
      grid.appendChild(card);
    }

    $('cashflow-section')?.classList.remove('hidden');
  }

  // ── Cash flow table ────────────────────────────────────────

  function renderCF() {
    if (!lastResults) return;
    const data = lastResults[currentCF]?.aylikNakitAkisi;
    if (!data?.length) return;

    const tbody = $('cashflow-tbody')!;
    tbody.innerHTML = '';

    const start = cfPage * CF_SIZE;
    const end = Math.min(start + CF_SIZE, data.length);

    for (let i = start; i < end; i++) {
      const r = data[i];
      const tr = document.createElement('tr');
      tr.className = 'hover:bg-brand-surface/50';
      tr.innerHTML = `
        <td class="px-3 py-2 text-xs text-brand-heading">${r.ay}</td>
        <td class="px-3 py-2 text-xs text-brand-heading text-right">${TL2.format(r.taksit)}</td>
        <td class="px-3 py-2 text-xs text-brand-heading text-right">${r.kira > 0 ? TL2.format(r.kira) : '-'}</td>
        <td class="px-3 py-2 text-xs text-brand-heading text-right">${(r.sigortaEkMaliyet + r.orgUcretTaksit) > 0 ? TL2.format(r.sigortaEkMaliyet + r.orgUcretTaksit) : '-'}</td>
        <td class="px-3 py-2 text-xs font-medium text-brand-heading text-right">${TL2.format(r.toplamCikis)}</td>
        <td class="px-3 py-2 text-xs text-brand-text text-right">${TL.format(r.kumulatifCikis)}</td>
        <td class="px-3 py-2 text-xs text-brand-text text-right">${TL2.format(r.indirgenmisDeger)}</td>
      `;
      tbody.appendChild(tr);
    }

    const info = $('cashflow-info');
    if (info) info.textContent = `${start + 1}–${end} / ${data.length} ay`;
    ($('cf-prev') as HTMLButtonElement).disabled = cfPage === 0;
    ($('cf-next') as HTMLButtonElement).disabled = end >= data.length;
  }

  $('cashflow-toggle')?.addEventListener('click', () => {
    const content = $('cashflow-content');
    const chevron = $('cashflow-chevron');
    const showing = content?.classList.toggle('hidden') === false;
    chevron?.style.setProperty('transform', showing ? 'rotate(180deg)' : '');
    if (showing) renderCF();
  });

  document.querySelectorAll<HTMLButtonElement>('.cf-model-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.cf-model-btn').forEach(b => { b.classList.remove('active-cf-btn'); b.classList.add('text-brand-text', 'hover:text-brand-heading'); });
      btn.classList.add('active-cf-btn');
      btn.classList.remove('text-brand-text', 'hover:text-brand-heading');
      currentCF = btn.dataset.cfModel as any;
      cfPage = 0;
      renderCF();
    });
  });

  $('cf-prev')?.addEventListener('click', () => { cfPage = Math.max(0, cfPage - 1); renderCF(); });
  $('cf-next')?.addEventListener('click', () => { cfPage++; renderCF(); });

  // ── Çekilişli scenario tabs ────────────────────────────────

  document.querySelectorAll<HTMLButtonElement>('.senaryo-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.senaryo-btn').forEach(b => { b.classList.remove('active-senaryo-btn'); b.classList.add('text-brand-text', 'hover:text-brand-heading'); });
      btn.classList.add('active-senaryo-btn');
      btn.classList.remove('text-brand-text', 'hover:text-brand-heading');

      if (!lastResults?.cekilisli) return;
      const s = btn.dataset.senaryo as 'enIyi' | 'beklenen' | 'enKotu';
      const evimR = lastResults.cekilisli[s];

      const all = [
        { key: 'banka', nbd: lastResults.banka.maliyetNBD },
        { key: 'evim', nbd: evimR.maliyetNBD },
        { key: 'biriktir', nbd: lastResults.biriktir.maliyetNBD },
      ].sort((a, b) => a.nbd - b.nbd);

      renderResults(lastResults.banka, evimR, lastResults.biriktir, all[0].key, lastResults.cekilisli);
    });
  });

  // ── Main calculation ───────────────────────────────────────

  function runCalculation() {
    clearError();

    const common = buildCommonParams();
    if (!common) return;
    const banka = buildBankaParams();
    if (!banka) return;
    const evim = buildEvimParams(common);
    if (!evim) return;
    const birikimP = buildBirikimParams(evim);
    if (!birikimP) return;

    try {
      const bankaR = hesaplaBankaNBD(common, banka);

      let evimR: ModelSonuc;
      let cekR: CekilisliSonuc | undefined;

      if (evim.model === 'cekilisli') {
        const grup = getNum('input-grupBuyuklugu') || 100;
        cekR = hesaplaCekilisliSenaryolar(common, evim, grup);
        evimR = cekR.beklenen;
      } else {
        evimR = hesaplaEvimNBD(common, evim);
      }

      const biriktirR = hesaplaBirikimNBD(common, evim, birikimP);

      const all = [
        { key: 'banka', nbd: bankaR.maliyetNBD },
        { key: 'evim', nbd: evimR.maliyetNBD },
        { key: 'biriktir', nbd: biriktirR.maliyetNBD },
      ].sort((a, b) => a.nbd - b.nbd);

      renderResults(bankaR, evimR, biriktirR, all[0].key, cekR);

      cfPage = 0;
      currentCF = 'banka';
      document.querySelectorAll('.cf-model-btn').forEach(b => { b.classList.remove('active-cf-btn'); b.classList.add('text-brand-text', 'hover:text-brand-heading'); });
      document.querySelector('[data-cf-model="banka"]')?.classList.add('active-cf-btn');
      document.querySelector('[data-cf-model="banka"]')?.classList.remove('text-brand-text', 'hover:text-brand-heading');

    } catch (err: any) {
      showError(`Hesaplama hatası: ${err.message || 'Bilinmeyen hata'}`);
      console.error(err);
    }
  }

  $('btn-karsilastir')?.addEventListener('click', runCalculation);

  // ── Initialize ─────────────────────────────────────────────
  showStep(1);
</script>
