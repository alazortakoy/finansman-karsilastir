---
import { Icon } from 'astro-icon/components';
---

<div id="wizard-step-1" class="wizard-step">
  <div class="bg-white border border-brand-border rounded-xl p-5 sm:p-6 shadow-sm">
    <div class="flex items-center gap-3 mb-2">
      <div class="w-8 h-8 rounded-lg bg-brand-primary text-white flex items-center justify-center text-sm font-bold shrink-0">1</div>
      <h2 class="font-heading text-lg font-semibold text-brand-heading">Temel Bilgiler</h2>
    </div>
    <p class="text-sm text-brand-text mb-6">Almayı düşündüğünüz konut veya aracın temel bilgilerini girin.</p>

    <div class="space-y-6">
      <!-- Asset Type Toggle -->
      <div>
        <label class="block text-sm font-medium text-brand-heading mb-1.5">Ne almak istiyorsunuz?</label>
        <p class="text-xs text-brand-text mb-2">Varlık tipine göre vergi oranları ve vade seçenekleri değişir.</p>
        <div class="grid grid-cols-2 gap-2 bg-brand-surface rounded-lg p-1">
          <button
            type="button"
            data-asset="konut"
            class="asset-type-btn active-asset-btn px-4 py-3 rounded-md text-sm font-medium transition-all"
          >
            <Icon name="tabler:home" class="w-4 h-4 inline-block mr-1.5 -mt-0.5" />
            Konut
          </button>
          <button
            type="button"
            data-asset="arac"
            class="asset-type-btn px-4 py-3 rounded-md text-sm font-medium transition-all text-brand-text hover:text-brand-heading"
          >
            <Icon name="tabler:car" class="w-4 h-4 inline-block mr-1.5 -mt-0.5" />
            Araç
          </button>
        </div>
        <input type="hidden" id="input-assetType" value="konut" />
      </div>

      <!-- Asset Value -->
      <div>
        <label for="input-F" class="block text-sm font-medium text-brand-heading mb-1">
          Konut / Araç Değeri
        </label>
        <p class="text-xs text-brand-text mb-2">Almayı düşündüğünüz konutun/aracın güncel piyasa değeri.</p>
        <div class="relative">
          <input
            type="text"
            inputmode="numeric"
            id="input-F"
            placeholder="5.000.000"
            value="5.000.000"
            class="calc-input w-full rounded-lg border border-brand-border bg-white px-4 py-3 text-base text-brand-heading placeholder:text-gray-400 focus:border-brand-primary focus:ring-2 focus:ring-brand-primary/20 focus:outline-none transition-all"
          />
          <span class="absolute right-4 top-1/2 -translate-y-1/2 text-sm text-brand-text pointer-events-none">TL</span>
        </div>
        <p class="mt-1 text-xs text-brand-text" id="hint-F">Min: 100.000 — Maks: 100.000.000 TL</p>
      </div>

      <!-- Down Payment -->
      <div>
        <label for="input-P" class="block text-sm font-medium text-brand-heading mb-1">
          Peşinat
          <span class="text-brand-text font-normal">(opsiyonel)</span>
        </label>
        <p class="text-xs text-brand-text mb-2">Elinizde bulunan ve peşin ödeyebileceğiniz tutar. Yoksa 0 bırakın.</p>
        <div class="relative">
          <input
            type="text"
            inputmode="numeric"
            id="input-P"
            placeholder="0"
            value="0"
            class="calc-input w-full rounded-lg border border-brand-border bg-white px-4 py-3 text-base text-brand-heading placeholder:text-gray-400 focus:border-brand-primary focus:ring-2 focus:ring-brand-primary/20 focus:outline-none transition-all"
          />
          <span class="absolute right-4 top-1/2 -translate-y-1/2 text-sm text-brand-text pointer-events-none">TL</span>
        </div>
      </div>
    </div>
  </div>
</div>
