---
import { Icon } from 'astro-icon/components';
---

<div id="wizard-step-4" class="wizard-step hidden">
  <div class="bg-white border border-brand-border rounded-xl p-5 sm:p-6 shadow-sm">
    <div class="flex items-center gap-3 mb-2">
      <div class="w-8 h-8 rounded-lg bg-brand-primary text-white flex items-center justify-center text-sm font-bold shrink-0">4</div>
      <h2 class="font-heading text-lg font-semibold text-brand-heading">
        <Icon name="tabler:home-hand" class="w-5 h-5 inline-block mr-1 -mt-0.5 text-teal-600" />
        Evim Sistemi
      </h2>
    </div>
    <p class="text-sm text-brand-text mb-6">Tasarruf finansman sistemi (Eminevim vb.) koşullarını girin.</p>

    <div class="space-y-5">
      <!-- Model Selection -->
      <div>
        <label class="block text-sm font-medium text-brand-heading mb-1">Evim Modeli</label>
        <p class="text-xs text-brand-text mb-2">Çekilişsiz modelde teslimat tarihi birikim oranına göre belirlenir. Çekilişli modelde kura ile belirlenir.</p>
        <div class="grid grid-cols-2 gap-2 bg-brand-surface rounded-lg p-1">
          <button
            type="button"
            data-evim-model="cekilissiz"
            class="evim-model-btn active-evim-btn px-4 py-2.5 rounded-md text-sm font-medium transition-all"
          >
            Çekilişsiz
          </button>
          <button
            type="button"
            data-evim-model="cekilisli"
            class="evim-model-btn px-4 py-2.5 rounded-md text-sm font-medium transition-all text-brand-text hover:text-brand-heading"
          >
            Çekilişli
          </button>
        </div>
        <input type="hidden" id="input-evim-model" value="cekilissiz" />
      </div>

      <!-- Organization Fee Rate -->
      <div>
        <label for="input-O_oran" class="block text-sm font-medium text-brand-heading mb-1">
          Organizasyon Ücreti Oranı
        </label>
        <p class="text-xs text-brand-text mb-2">
          Finanse edilen tutar üzerinden alınan bir defaya mahsus ücret. Şirket ve kampanyaya göre değişebilir.
        </p>
        <div class="relative">
          <input
            type="number"
            id="input-O_oran"
            step="0.5"
            min="0"
            max="20"
            value="8"
            class="calc-input w-full rounded-lg border border-brand-border bg-white px-4 py-3 text-base text-brand-heading placeholder:text-gray-400 focus:border-brand-primary focus:ring-2 focus:ring-brand-primary/20 focus:outline-none transition-all"
          />
          <span class="absolute right-4 top-1/2 -translate-y-1/2 text-sm text-brand-text pointer-events-none">%</span>
        </div>
        <p class="mt-1 text-xs text-brand-text">Varsayılan %8 — (F−P) tutarı üzerinden hesaplanır</p>
      </div>

      <!-- Total Term — defaults to banka n_b -->
      <div>
        <label for="input-n_e" class="block text-sm font-medium text-brand-heading mb-1">
          Toplam Vade
        </label>
        <p class="text-xs text-brand-text mb-2">
          Karşılaştırma için banka kredisi vadesiyle aynı tutmanız önerilir.
        </p>
        <div class="relative">
          <input
            type="number"
            id="input-n_e"
            step="12"
            min="12"
            max="240"
            value="120"
            class="calc-input w-full rounded-lg border border-brand-border bg-white px-4 py-3 text-base text-brand-heading placeholder:text-gray-400 focus:border-brand-primary focus:ring-2 focus:ring-brand-primary/20 focus:outline-none transition-all"
          />
          <span class="absolute right-4 top-1/2 -translate-y-1/2 text-sm text-brand-text pointer-events-none">ay</span>
        </div>
        <p class="mt-1 text-xs text-brand-text" id="hint-n_e">Banka vadesi ile senkronize: <span id="sync-vade-info" class="font-medium text-brand-primary">120 ay</span></p>
      </div>

      <!-- Installment Plan (3 options, no manuel) -->
      <div>
        <label class="block text-sm font-medium text-brand-heading mb-1">Taksit Planı</label>
        <p class="text-xs text-brand-text mb-2">Taksitlerin nasıl hesaplanacağını seçin.</p>
        <div class="grid grid-cols-3 gap-1.5 bg-brand-surface rounded-lg p-1">
          <button type="button" data-taksit-plan="sabit" class="taksit-plan-btn active-taksit-btn px-2 py-2 rounded-md text-xs font-medium transition-all">
            Sabit
          </button>
          <button type="button" data-taksit-plan="yillikArtisli" class="taksit-plan-btn px-2 py-2 rounded-md text-xs font-medium transition-all text-brand-text hover:text-brand-heading">
            Yıllık Artışlı
          </button>
          <button type="button" data-taksit-plan="teslimatSonrasiArtisli" class="taksit-plan-btn px-2 py-2 rounded-md text-xs font-medium transition-all text-brand-text hover:text-brand-heading">
            Teslim Sonrası
          </button>
        </div>
        <input type="hidden" id="input-taksitPlan" value="sabit" />
      </div>

      <!-- Sabit Plan — Auto calculated, no input -->
      <div id="plan-sabit" class="plan-fields">
        <div class="bg-brand-surface rounded-lg p-4 border border-brand-border-light">
          <div class="flex items-center gap-2 mb-1">
            <Icon name="tabler:calculator" class="w-4 h-4 text-brand-primary" />
            <p class="text-xs font-medium text-brand-heading">Otomatik Hesaplanan Aylık Taksit</p>
          </div>
          <p class="text-2xl font-heading font-bold text-brand-heading" id="sabit-taksit-display" style="font-variant-numeric:tabular-nums">—</p>
          <p class="text-xs text-brand-text mt-1">(Finanse edilen tutar ÷ Toplam vade)</p>
        </div>
      </div>

      <!-- Yıllık Artışlı Plan Fields -->
      <div id="plan-yillikArtisli" class="plan-fields hidden space-y-3">
        <div>
          <label for="input-baslangicTutar" class="block text-xs font-medium text-brand-heading mb-1">Başlangıç Taksit Tutarı</label>
          <div class="relative">
            <input type="text" inputmode="numeric" id="input-baslangicTutar" placeholder="40.000" class="calc-input w-full rounded-lg border border-brand-border bg-white px-4 py-2.5 text-base text-brand-heading placeholder:text-gray-400 focus:border-brand-primary focus:ring-2 focus:ring-brand-primary/20 focus:outline-none transition-all" />
            <span class="absolute right-4 top-1/2 -translate-y-1/2 text-xs text-brand-text pointer-events-none">TL/ay</span>
          </div>
        </div>
        <div>
          <label for="input-yillikArtisOrani" class="block text-xs font-medium text-brand-heading mb-1">Yıllık Artış Oranı</label>
          <div class="relative">
            <input type="number" id="input-yillikArtisOrani" step="1" min="0" max="200" placeholder="25" class="calc-input w-full rounded-lg border border-brand-border bg-white px-4 py-2.5 text-base text-brand-heading placeholder:text-gray-400 focus:border-brand-primary focus:ring-2 focus:ring-brand-primary/20 focus:outline-none transition-all" />
            <span class="absolute right-4 top-1/2 -translate-y-1/2 text-xs text-brand-text pointer-events-none">%</span>
          </div>
        </div>
      </div>

      <!-- Teslimat Sonrası Artışlı Plan Fields -->
      <div id="plan-teslimatSonrasiArtisli" class="plan-fields hidden space-y-3">
        <div>
          <label for="input-teslimOncesiTutar" class="block text-xs font-medium text-brand-heading mb-1">Teslim Öncesi Taksit</label>
          <div class="relative">
            <input type="text" inputmode="numeric" id="input-teslimOncesiTutar" placeholder="30.000" class="calc-input w-full rounded-lg border border-brand-border bg-white px-4 py-2.5 text-base text-brand-heading placeholder:text-gray-400 focus:border-brand-primary focus:ring-2 focus:ring-brand-primary/20 focus:outline-none transition-all" />
            <span class="absolute right-4 top-1/2 -translate-y-1/2 text-xs text-brand-text pointer-events-none">TL/ay</span>
          </div>
        </div>
        <div>
          <label for="input-teslimSonrasiTutar" class="block text-xs font-medium text-brand-heading mb-1">Teslim Sonrası Taksit</label>
          <div class="relative">
            <input type="text" inputmode="numeric" id="input-teslimSonrasiTutar" placeholder="70.000" class="calc-input w-full rounded-lg border border-brand-border bg-white px-4 py-2.5 text-base text-brand-heading placeholder:text-gray-400 focus:border-brand-primary focus:ring-2 focus:ring-brand-primary/20 focus:outline-none transition-all" />
            <span class="absolute right-4 top-1/2 -translate-y-1/2 text-xs text-brand-text pointer-events-none">TL/ay</span>
          </div>
        </div>
        <div>
          <label for="input-teslimSonrasiArtis" class="block text-xs font-medium text-brand-heading mb-1">Yıllık Artış Oranı</label>
          <div class="relative">
            <input type="number" id="input-teslimSonrasiArtis" step="1" min="0" max="200" placeholder="25" class="calc-input w-full rounded-lg border border-brand-border bg-white px-4 py-2.5 text-base text-brand-heading placeholder:text-gray-400 focus:border-brand-primary focus:ring-2 focus:ring-brand-primary/20 focus:outline-none transition-all" />
            <span class="absolute right-4 top-1/2 -translate-y-1/2 text-xs text-brand-text pointer-events-none">%</span>
          </div>
        </div>
      </div>

      <!-- Delivery Month — Çekilişsiz: auto display only -->
      <div id="teslim-cekilissiz">
        <div class="bg-brand-surface rounded-lg p-4 border border-brand-border-light">
          <div class="flex items-center gap-2 mb-1">
            <Icon name="tabler:calendar-check" class="w-4 h-4 text-brand-primary" />
            <p class="text-xs font-medium text-brand-heading">Tahmini Teslimat Ayı</p>
          </div>
          <p class="text-2xl font-heading font-bold text-brand-heading" id="teslim-display" style="font-variant-numeric:tabular-nums">—</p>
          <p class="text-xs text-brand-text mt-1">Kümülatif birikim ≥ %40 koşuluna göre otomatik hesaplanır.</p>
        </div>
        <input type="hidden" id="input-t_teslim" value="" />
      </div>

      <!-- Çekilişli: Group Size -->
      <div id="teslim-cekilisli" class="hidden">
        <label for="input-grupBuyuklugu" class="block text-sm font-medium text-brand-heading mb-1">
          Grup Büyüklüğü
        </label>
        <p class="text-xs text-brand-text mb-2">Çekilişli sistemde kaç kişilik bir gruba dahilsiniz?</p>
        <div class="relative">
          <input
            type="number"
            id="input-grupBuyuklugu"
            min="10"
            max="500"
            value="100"
            class="calc-input w-full rounded-lg border border-brand-border bg-white px-4 py-3 text-base text-brand-heading placeholder:text-gray-400 focus:border-brand-primary focus:ring-2 focus:ring-brand-primary/20 focus:outline-none transition-all"
          />
          <span class="absolute right-4 top-1/2 -translate-y-1/2 text-sm text-brand-text pointer-events-none">kişi</span>
        </div>
        <div class="mt-2 flex items-start gap-2 bg-brand-warning/10 rounded-lg p-2.5">
          <Icon name="tabler:info-circle" class="w-4 h-4 text-brand-warning shrink-0 mt-0.5" />
          <p class="text-xs text-brand-text leading-relaxed">
            Çekilişli modelde teslimat tarihi belirsizdir. Sonuçlar en iyi, beklenen ve en kötü senaryo olarak gösterilir.
          </p>
        </div>
      </div>

      <!-- Rent Support -->
      <div class="border-t border-brand-border-light pt-5">
        <div class="flex items-center justify-between mb-1">
          <label class="text-sm font-medium text-brand-heading">Kira Desteği</label>
          <label class="relative inline-flex items-center cursor-pointer">
            <input type="checkbox" id="toggle-kiraDestegi" class="sr-only peer" />
            <div class="w-9 h-5 bg-gray-200 peer-focus:outline-none peer-focus:ring-2 peer-focus:ring-brand-primary/20 rounded-full peer peer-checked:after:translate-x-full rtl:peer-checked:after:-translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-4 after:w-4 after:transition-all peer-checked:bg-brand-primary"></div>
          </label>
        </div>
        <p class="text-xs text-brand-text mb-3">
          Evim sistemi şirketleri (Eminevim vb.) teslimat öncesi dönemde kira giderinizin bir kısmını karşılayabilir. Bu tutar sözleşmenize göre değişir.
        </p>
        <div id="kiraDestegi-panel" class="hidden">
          <label for="input-kiraDestegi" class="block text-xs font-medium text-brand-heading mb-1">Aylık Kira Desteği Tutarı</label>
          <div class="relative">
            <input type="text" inputmode="numeric" id="input-kiraDestegi" placeholder="5.000" class="calc-input w-full rounded-lg border border-brand-border bg-white px-4 py-2.5 text-base text-brand-heading placeholder:text-gray-400 focus:border-brand-primary focus:ring-2 focus:ring-brand-primary/20 focus:outline-none transition-all" />
            <span class="absolute right-4 top-1/2 -translate-y-1/2 text-xs text-brand-text pointer-events-none">TL/ay</span>
          </div>
          <p class="mt-1 text-xs text-brand-text">Sözleşmenizde belirtilen aylık kira desteği tutarını girin.</p>
        </div>
      </div>

      <!-- Org Fee Payment Plan -->
      <div class="border-t border-brand-border-light pt-5 space-y-3">
        <p class="text-sm font-medium text-brand-heading">Organizasyon Ücreti Ödeme Planı</p>
        <p class="text-xs text-brand-text">Org ücretinin ne kadarını peşin ödeyeceksiniz?</p>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label for="input-orgPesinOran" class="block text-xs font-medium text-brand-heading mb-1">Peşin Oran</label>
            <div class="relative">
              <input type="number" id="input-orgPesinOran" step="5" min="50" max="100" value="50" class="calc-input w-full rounded-lg border border-brand-border bg-white px-3 py-2.5 text-base text-brand-heading focus:border-brand-primary focus:ring-2 focus:ring-brand-primary/20 focus:outline-none transition-all" />
              <span class="absolute right-3 top-1/2 -translate-y-1/2 text-xs text-brand-text pointer-events-none">%</span>
            </div>
            <p class="mt-0.5 text-[10px] text-brand-text">Min %50 (BDDK)</p>
          </div>
          <div>
            <label for="input-orgTaksitSayisi" class="block text-xs font-medium text-brand-heading mb-1">Taksit Sayısı</label>
            <input type="number" id="input-orgTaksitSayisi" min="0" max="4" value="4" class="calc-input w-full rounded-lg border border-brand-border bg-white px-3 py-2.5 text-base text-brand-heading focus:border-brand-primary focus:ring-2 focus:ring-brand-primary/20 focus:outline-none transition-all" />
            <p class="mt-0.5 text-[10px] text-brand-text">Maks 4 taksit</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
